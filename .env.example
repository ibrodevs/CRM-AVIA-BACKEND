# Travel Hub CRM backend — пример конфигурации. Секретов здесь нет.
# Скопируйте в .env и заполните реальными значениями.

DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=replace-with-at-least-32-random-bytes-before-deployment
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Локально и на бесплатном PythonAnywhere можно использовать SQLite.
# При DJANGO_SETTINGS_MODULE=config.settings.pythonanywhere эта переменная
# необязательна: база по умолчанию создаётся в BASE_DIR/db.sqlite3.
# DATABASE_URL=sqlite:////home/USERNAME/CRM-AVIA-BACKEND/db.sqlite3
SQLITE_TIMEOUT=20

# Для PostgreSQL укажите URL явно:
# DATABASE_URL=postgres:///travelhub
# TEST_DATABASE_URL=postgres:///travelhub_test

# JWT (по умолчанию используется DJANGO_SECRET_KEY)
# JWT_SIGNING_KEY=

# Шифрование полей (паспорта, реквизиты, provider secrets).
# Генерация: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# Бизнес-настройки
BUSINESS_TIMEZONE=Asia/Bishkek
BASE_CURRENCY=USD
EVENT_RETENTION_DAYS=7
MULTI_CITY_MAX_SEGMENTS=6
ALLOW_MOCK_ADAPTER=True

# Job runner
JOB_BATCH_SIZE=10
JOB_HEARTBEAT_SECONDS=30
JOB_STALE_AFTER_SECONDS=180
JOB_DEFAULT_MAX_ATTEMPTS=5

# Production / PythonAnywhere
# DJANGO_SETTINGS_MODULE=config.settings.pythonanywhere
# DJANGO_ALLOWED_HOSTS=USERNAME.pythonanywhere.com
# CSRF_TRUSTED_ORIGINS=https://USERNAME.pythonanywhere.com
# SECURE_SSL_REDIRECT=False
# ALLOW_MOCK_ADAPTER=False
LOG_LEVEL=INFO
